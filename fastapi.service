[Unit]
Description=Gunicorn daemon for FastAPI application
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/home/ubuntu/pupy
# Path to your virtual environment's bin directory
Environment="PATH=/home/ubuntu/pupy/venv/bin"
# Run Gunicorn with Uvicorn workers
ExecStart=/home/ubuntu/pupy/venv/bin/gunicorn -k uvicorn.workers.UvicornWorker -w 4 -b 127.0.0.1:8000 single_file_app:app

# Restart settings
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
